+fn restore_webview(embed: Embed) {
+    set_webview_opaque(&embed.web_view);
+    if let Some(parent) = embed.web_view.parent() {
+        if let Some(container) = parent.downcast_ref::<gtk::Container>() {
+            container.remove(&embed.web_view);
